# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Required — used to sign JWTs. Generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Frontend origin for CORS (production URL)
FRONTEND_URL=https://backyard-marquee.vercel.app

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server port
PORT=3001

# Turso database (use file:./db/backyard-marquee.db for local dev)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
