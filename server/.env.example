# Required — used to sign JWTs. Generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Turso database
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Frontend origin for CORS (production URL)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3001

# Admin seed (required for first run — creates the initial admin account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately
ADMIN_DISPLAY_NAME=Admin

# Email / password reset (optional — if not set, reset emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@involuntaryresponse.com
