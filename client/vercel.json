{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(bot|crawl|spider|facebookexternalhit|Twitterbot|Slackbot|TelegramBot|WhatsApp|LinkedInBot|Discordbot|Applebot|Googlebot|Bingbot|iMessageBot)"
        }
      ],
      "destination": "/api/og"
    },
    { "source": "/api/:path*", "destination": "https://involuntary-response-api.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
